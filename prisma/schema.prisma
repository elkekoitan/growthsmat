// SmartGrowth OS — Prisma şeması (Phase 0: auth/tenancy çekirdeği)
// Prisma 7: datasource'ta url YOK (bkz. prisma.config.ts) — çalışma zamanı bağlantısı
// src/lib/db.ts'te @prisma/adapter-pg üzerinden verilir (driver adapter deseni).
// Referans/statik veri (crops.ts, rulePacks.ts'in RULE_PACKS'ı vb.) burada YOK — bu şema
// yalnız gerçek, kullanıcı-mutasyonlu varlıkları kapsar (bkz. plan dosyası §2).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Kimlik ve çok-kiracılık çekirdeği (Phase 0) ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions       Session[]
  memberships    Membership[]
  sentInvites    Invite[]     @relation("InvitedBy")
  reviewedInvites AuditEvent[]
  buyerOrders    Order[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  Membership[]
  invites      Invite[]
  certificates Certificate[]
  listings     Listing[]
  buyerOrders  Order[]
  plan         Plan?
  tasks        Task[]
}

enum Role {
  sahip
  yonetici
  planlayici
  saha_calisani @map("saha-calisani")
  kalite
  satis
  goruntuleyici
  uzman
}

enum MembershipStatus {
  aktif
  askida
  iptal
}

model Membership {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        Role
  status      MembershipStatus @default(aktif)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

enum InviteState {
  davet_gonderildi @map("davet-gonderildi")
  kabul_edildi     @map("kabul-edildi")
  reddedildi
  suresi_doldu     @map("suresi-doldu")
  iptal_edildi     @map("iptal-edildi")
}

model Invite {
  id              String      @id @default(cuid())
  email           String
  workspaceId     String
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role            Role
  invitedByUserId String
  invitedBy       User        @relation("InvitedBy", fields: [invitedByUserId], references: [id])
  sentAt          DateTime    @default(now())
  expiresAt       DateTime
  state           InviteState @default(davet_gonderildi)

  auditEvents AuditEvent[]

  @@index([workspaceId])
  @@index([email])
}

model AuditEvent {
  id       String   @id @default(cuid())
  at       DateTime @default(now())
  action   String
  inviteId String
  invite   Invite   @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  actorUserId String
  actor    User     @relation(fields: [actorUserId], references: [id])

  @@index([inviteId])
}

enum Jurisdiction {
  TR
  EU
  US
  CA
  AU
  JP
  CODEX
  SA
  UK
}

model Certificate {
  id            String       @id @default(cuid())
  holder        String
  jurisdiction  Jurisdiction
  scopeCropIds  String[]
  validFrom     DateTime
  validTo       DateTime
  issuer        String
  inTransition  Boolean      @default(false)
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workspaceId])
}

// ---------- Pazar / ticaret çekirdeği (gerçek ilan ve sipariş, P10) ----------
// DÜRÜSTLÜK NOTU ("sahte kesinlik yok"): Order burada GERÇEK bir ödeme işlemi DEĞİLDİR.
// Hiçbir ödeme ağ geçidi (Stripe/PayTR/iyzico vb.) entegre edilmemiştir; bu şema/uygulama
// para hareketi ETMEZ. Order, iki gerçek hesap (alıcı workspace ↔ satıcı workspace)
// arasında kalıcı olarak saklanan bir SATIN ALMA TALEBİ kaydıdır — "beklemede" durumunda
// oluşur, satıcı onaylar ("onaylandi") veya taraflardan biri iptal eder ("iptal"); gerçek
// ödeme tahsilatı/entegrasyonu bilinçli olarak bu turun kapsamı DIŞINDA bırakılmıştır.

model Listing {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // cropId/microgreenId: src/data/crops.ts ve src/data/microgreens.ts'teki statik kataloglara
  // düz string referanstır (Task.cropId ile aynı desen) — bilinçli olarak bir DB foreign key
  // DEĞİLDİR; bu kataloglar kod içinde yaşayan referans veridir, ayrı bir tablo gerektirmez.
  cropId          String?
  microgreenId    String?
  title           String
  producer        String
  region          String
  format          String
  unitLabel       String
  priceTRY        Float
  stockType       String
  channels        String[]
  claim           String
  shelfLifeDays   Int
  repeatOrderRate Float
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders Order[]

  @@index([workspaceId])
  @@index([active])
}

model Order {
  id               String    @id @default(cuid())
  listingId        String
  listing          Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerUserId      String
  buyerUser        User      @relation(fields: [buyerUserId], references: [id])
  buyerWorkspaceId String
  buyerWorkspace   Workspace @relation(fields: [buyerWorkspaceId], references: [id])
  quantity         Float
  totalPriceTRY    Float
  // Yalnız "beklemede" | "onaylandi" | "iptal" — gerçek bir ödeme/tahsilat durumu DEĞİL,
  // yalnızca sipariş talebinin işleniş durumu (bkz. src/server/repositories/orders.ts).
  status    String   @default("beklemede")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([buyerWorkspaceId])
  @@index([buyerUserId])
}

// ---------- Plan + Görevler (Phase 2: uygunluk sihirbazı + saha günlüğü) ----------
// DÜRÜSTLÜK NOTU: Plan yalnız sihirbazın HAM girdisini (SiteProfile, src/lib/suitability.ts)
// saklar — hesaplanan AssessmentResult (skor/güven/senaryo) hiçbir zaman kalıcılaştırılmaz,
// her okunuşta runAssessment() ile YENİDEN hesaplanır. Bir workspace'in tek, güncel plan
// satırı olur (localStorage'daki tek "sg-plan" anahtarıyla aynı anlam — upsert edilir).
// method/goal/season: GrowMethod/Goal/Season TS union'larının düz string karşılığıdır;
// Listing.format/stockType ile aynı desen — repository katmanında doğrulanır, DB seviyesinde
// enum zorlanmaz (statik TS union tek doğruluk kaynağı kalır).

model Plan {
  id            String    @id @default(cuid())
  workspaceId   String    @unique
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  city          String
  method        String
  areaM2        Float
  sunHours      Float
  containerL    Float?
  waterAccess   Int
  weeklyMinutes Int
  experience    Int
  goal          String
  hasKidsOrPets Boolean
  season        String
  phMeasured    Boolean   @default(false)
  phValue       Float     @default(6.5)
  completed     Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ekim/sulama/gubre/budama/gozlem/hasat — src/lib/taskTemplates.ts'teki TaskKind ile birebir
// aynı (eski Tasks.tsx'in "gubreleme" yazımı burada KASITLI OLARAK terk edildi — iki dosya
// arasındaki gerçek bir yazım tutarsızlığıydı, tek kanonik değer bu enum'dur; Türkçe arayüz
// etiketi "Gübreleme" değişmedi, yalnız alttaki değer değişti — bkz. src/lib/roles.ts'teki
// @map deseniyle aynı "DB değeri ≠ görüntü etiketi" ilkesi).
enum TaskKind {
  ekim
  sulama
  gubre
  budama
  gozlem
  hasat
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type        TaskKind
  title       String
  // cropId: Listing.cropId ile aynı desen — src/data/crops.ts'e düz string referans, DB FK değil.
  cropId      String
  zone        String
  date        DateTime  @db.Date
  done        Boolean   @default(false)
  critical    Boolean   @default(false)
  note        String?
  measurement String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, date])
}
