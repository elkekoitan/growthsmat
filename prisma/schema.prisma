// SmartGrowth OS — Prisma şeması (Phase 0: auth/tenancy çekirdeği)
// Prisma 7: datasource'ta url YOK (bkz. prisma.config.ts) — çalışma zamanı bağlantısı
// src/lib/db.ts'te @prisma/adapter-pg üzerinden verilir (driver adapter deseni).
// Referans/statik veri (crops.ts, rulePacks.ts'in RULE_PACKS'ı vb.) burada YOK — bu şema
// yalnız gerçek, kullanıcı-mutasyonlu varlıkları kapsar (bkz. plan dosyası §2).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Kimlik ve çok-kiracılık çekirdeği (Phase 0) ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions       Session[]
  memberships    Membership[]
  sentInvites    Invite[]     @relation("InvitedBy")
  reviewedInvites AuditEvent[]
  buyerOrders    Order[]
  assignedTasks  Task[]       @relation("TaskAssignee")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  // 03-TEKNIK-MIMARI.md §6.1'in workspaces(...) şemasında dokümante edilen alan — önceden
  // hiç yoktu, /pazar'daki sertifika jurisdiction seçici bu yüzden "8/9 seçenek etkisiz"
  // durumundaydı (yalnız sabit DEFAULT_JURISDICTION="TR" kontrol ediliyordu, workspace'in
  // KENDİ yargı alanı hiç yoktu). Varsayılan TR (ADR-009: tek pazardan başla) — henüz
  // değiştirmek için bir ayarlar UI'ı yok, bilinçli bırakılan bir sonraki adım.
  homeJurisdiction Jurisdiction @default(TR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  Membership[]
  invites      Invite[]
  certificates Certificate[]
  listings     Listing[]
  buyerOrders  Order[]
  plan         Plan?
  tasks        Task[]
  lots         Lot[]
  devices      Device[]
  featureFlagOverrides FeatureFlagOverride[]
  room         Room?
  subscriptions Subscription[]
  costCycles   CostCycle[]
}

enum Role {
  sahip
  yonetici
  planlayici
  saha_calisani @map("saha-calisani")
  kalite
  satis
  goruntuleyici
  uzman
}

enum MembershipStatus {
  aktif
  askida
  iptal
}

model Membership {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        Role
  status      MembershipStatus @default(aktif)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

enum InviteState {
  davet_gonderildi @map("davet-gonderildi")
  kabul_edildi     @map("kabul-edildi")
  reddedildi
  suresi_doldu     @map("suresi-doldu")
  iptal_edildi     @map("iptal-edildi")
}

model Invite {
  id              String      @id @default(cuid())
  email           String
  workspaceId     String
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role            Role
  invitedByUserId String
  invitedBy       User        @relation("InvitedBy", fields: [invitedByUserId], references: [id])
  sentAt          DateTime    @default(now())
  expiresAt       DateTime
  state           InviteState @default(davet_gonderildi)

  auditEvents AuditEvent[]

  @@index([workspaceId])
  @@index([email])
}

model AuditEvent {
  id       String   @id @default(cuid())
  at       DateTime @default(now())
  action   String
  inviteId String
  invite   Invite   @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  actorUserId String
  actor    User     @relation(fields: [actorUserId], references: [id])

  @@index([inviteId])
}

enum Jurisdiction {
  TR
  EU
  US
  CA
  AU
  JP
  CODEX
  SA
  UK
}

enum CertificateVerificationStatus {
  beklemede
  onaylandi
  reddedildi
  iptal_edildi @map("iptal-edildi")
}

model Certificate {
  id            String       @id @default(cuid())
  holder        String
  jurisdiction  Jurisdiction
  scopeCropIds  String[]
  validFrom     DateTime
  validTo       DateTime
  issuer        String
  inTransition  Boolean      @default(false)
  // FR-125 ("...ve belge kaydı"): sertifikanın kendisine (PDF/görsel) referans — dosya
  // yükleme altyapısı henüz yok, bu yüzden şimdilik yalnız bir URL/referans metni alanı.
  documentUrl   String?
  // Kayıt anında sertifika yalnız bir İDDİADIR (bkz. src/lib/certificateReview.ts) —
  // compliance.review izinli bir rol onaylamadan evaluateWorkspaceClaim() bu satırı
  // asla dikkate almaz (bkz. repositories/certificates.ts).
  verificationStatus CertificateVerificationStatus @default(beklemede)
  verifiedBy    String?
  verifiedAt    DateTime?
  verificationNote String?
  // FR-183: daha önce onaylanmış bir sertifikanın geriye dönük iptali (bkz.
  // src/lib/certificateReview.ts revokeCertificate) — verifiedBy/verifiedAt'in
  // ÜZERİNE YAZMAZ, orijinal onayı kimin/ne zaman yaptığı ayrı bir denetim izi olarak kalır.
  revokedBy     String?
  revokedAt     DateTime?
  revocationNote String?
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workspaceId])
  @@index([verificationStatus])
}

// ---------- Pazar / ticaret çekirdeği (gerçek ilan ve sipariş, P10) ----------
// DÜRÜSTLÜK NOTU ("sahte kesinlik yok"): Order burada GERÇEK bir ödeme işlemi DEĞİLDİR.
// Hiçbir ödeme ağ geçidi (Stripe/PayTR/iyzico vb.) entegre edilmemiştir; bu şema/uygulama
// para hareketi ETMEZ. Order, iki gerçek hesap (alıcı workspace ↔ satıcı workspace)
// arasında kalıcı olarak saklanan bir SATIN ALMA TALEBİ kaydıdır — "beklemede" durumunda
// oluşur, satıcı onaylar ("onaylandi") veya taraflardan biri iptal eder ("iptal"); gerçek
// ödeme tahsilatı/entegrasyonu bilinçli olarak bu turun kapsamı DIŞINDA bırakılmıştır.

model Listing {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // cropId/microgreenId: src/data/crops.ts ve src/data/microgreens.ts'teki statik kataloglara
  // düz string referanstır (Task.cropId ile aynı desen) — bilinçli olarak bir DB foreign key
  // DEĞİLDİR; bu kataloglar kod içinde yaşayan referans veridir, ayrı bir tablo gerektirmez.
  cropId          String?
  microgreenId    String?
  title           String
  producer        String
  region          String
  format          String
  unitLabel       String
  priceTRY        Float
  stockType       String
  // Gerçek envanter adedi — stockType yalnız kategorik bir etikettir (ör. "tahmini-hasat"),
  // GERÇEK stok takibi (siparişte azalt, iptalde geri ekle, tükenince sipariş engelle) bu
  // alana bağlıdır. 0 = tükendi. placeOrder() atomik olarak azaltır (bkz. orders.ts).
  stockQty        Int      @default(0)
  channels        String[]
  claim           String
  shelfLifeDays   Int
  repeatOrderRate Float
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders Order[]

  @@index([workspaceId])
  @@index([active])
}

model Order {
  id               String    @id @default(cuid())
  listingId        String
  listing          Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerUserId      String
  buyerUser        User      @relation(fields: [buyerUserId], references: [id])
  buyerWorkspaceId String
  buyerWorkspace   Workspace @relation(fields: [buyerWorkspaceId], references: [id])
  quantity         Float
  totalPriceTRY    Float
  // Yalnız "beklemede" | "onaylandi" | "iptal" — gerçek bir ödeme/tahsilat durumu DEĞİL,
  // yalnızca sipariş talebinin işleniş durumu (bkz. src/server/repositories/orders.ts).
  status    String   @default("beklemede")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([buyerWorkspaceId])
  @@index([buyerUserId])
}

// ---------- Plan + Görevler (Phase 2: uygunluk sihirbazı + saha günlüğü) ----------
// DÜRÜSTLÜK NOTU: Plan yalnız sihirbazın HAM girdisini (SiteProfile, src/lib/suitability.ts)
// saklar — hesaplanan AssessmentResult (skor/güven/senaryo) hiçbir zaman kalıcılaştırılmaz,
// her okunuşta runAssessment() ile YENİDEN hesaplanır. Bir workspace'in tek, güncel plan
// satırı olur (localStorage'daki tek "sg-plan" anahtarıyla aynı anlam — upsert edilir).
// method/goal/season: GrowMethod/Goal/Season TS union'larının düz string karşılığıdır;
// Listing.format/stockType ile aynı desen — repository katmanında doğrulanır, DB seviyesinde
// enum zorlanmaz (statik TS union tek doğruluk kaynağı kalır).

model Plan {
  id            String    @id @default(cuid())
  workspaceId   String    @unique
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  city          String
  method        String
  areaM2        Float
  sunHours      Float
  containerL    Float?
  waterAccess   Int
  weeklyMinutes Int
  experience    Int
  goal          String
  hasKidsOrPets Boolean
  season        String
  phMeasured    Boolean   @default(false)
  phValue       Float     @default(6.5)
  completed     Boolean   @default(false)
  // ADR-004 (Öneri motoru): "Her karar input snapshot ve motor sürümüyle saklanır" —
  // hesaplanan sonuç saklanmaz (yukarıdaki dürüstlük notu), ama HANGİ motor sürümüyle
  // üretildiği saklanır (src/lib/suitability.ts ENGINE_VERSION) — motor ileride değişirse
  // eski planların hangi mantıkla üretildiği izlenebilir kalır.
  engineVersion String    @default("suitability-v1.0.0")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ekim/sulama/gubre/budama/gozlem/hasat — src/lib/taskTemplates.ts'teki TaskKind ile birebir
// aynı (eski Tasks.tsx'in "gubreleme" yazımı burada KASITLI OLARAK terk edildi — iki dosya
// arasındaki gerçek bir yazım tutarsızlığıydı, tek kanonik değer bu enum'dur; Türkçe arayüz
// etiketi "Gübreleme" değişmedi, yalnız alttaki değer değişti — bkz. src/lib/roles.ts'teki
// @map deseniyle aynı "DB değeri ≠ görüntü etiketi" ilkesi).
enum TaskKind {
  ekim
  sulama
  gubre
  budama
  gozlem
  hasat
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type        TaskKind
  title       String
  // cropId: Listing.cropId ile aynı desen — src/data/crops.ts'e düz string referans, DB FK değil.
  cropId      String
  zone        String
  date        DateTime  @db.Date
  done        Boolean   @default(false)
  critical    Boolean   @default(false)
  note        String?
  measurement String?
  // Görev atama (P06-05, Phase 6b'de gerçek çok-kişili workspace'ler mümkün olduktan sonra
  // anlamlı hale geldi) — atanan kişi workspace'ten AYRILIRSA/rolü değişirse bile geçmiş
  // atama kaydı silinmez (SetNull ile yalnız referans temizlenir, görev kalır).
  assignedToUserId String?
  assignedTo       User?   @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, date])
  @@index([assignedToUserId])
}

// ---------- Lot izlenebilirlik (Phase 3: src/lib/traceability.ts) ----------
// DÜRÜSTLÜK NOTU: eski /izlenebilirlik yalnız 8 lotluk SABİT bir örnek zinciri (LOTS
// sabiti) gösteren, gerçek lot oluşturma imkânı OLMAYAN bir demoydu. Bu faz gerçek bir
// "lot kaydet" akışı ekler (bkz. src/app/izlenebilirlik/actions.ts) — artık salt-okunur
// bir vitrin değil. `code`: kullanıcının kendi atadığı, workspace içinde benzersiz lot
// kodu (ör. "SEED-2026-014") — src/lib/traceability.ts'teki Lot.id ile eşleşir; asıl
// Prisma `id` (cuid) yalnız iç FK hedefi. parentLotIds (string dizisi) LotGenealogy join
// tablosuyla GERÇEK referans bütünlüğü kazanır — repository katmanı diziyi okurken/
// yazarken yeniden kurar (bkz. plan dosyası §2, Phase 3).
enum LotType {
  tohum
  girdi
  uretim
  hasat
  paket
  sevkiyat
}

enum LotStatus {
  aktif
  incelemede
  karantina
  geri_cagrildi @map("geri-cagrildi")
  tuketildi
}

model Lot {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  code            String
  label           String
  type            LotType
  // cropId: Listing.cropId ile aynı desen — src/data/crops.ts'e düz string referans, DB FK değil.
  cropId          String?
  quantity        Float
  unit            String
  producedAt      DateTime  @db.Date
  status          LotStatus @default(aktif)
  certifiedOrigin Boolean   @default(false)
  ownerLabel      String
  // 03-TEKNIK-MIMARI.md §6.5'in operations(...performed_by) alanına karşılık gelen, GERÇEK
  // (kullanıcı tarafından yazılabilen serbest metin ownerLabel'dan farklı olarak) bir denetim
  // izi — bu lotu GERÇEKTEN kim, hangi hesapla kaydetti. Var olan tek lot-mutasyonu (createLot)
  // için ayrı bir genel "Operation" tablosu kurmak bu aşamada aşırı mühendislik olurdu (tek
  // kullanım noktası) — ikinci bir mutasyon türü (ör. gerçek geri çağırma yürütme) eklendiğinde
  // yeniden değerlendirilmeli.
  createdByUserId String?
  createdByEmail  String?

  parentEdges LotGenealogy[] @relation("ChildLot")
  childEdges  LotGenealogy[] @relation("ParentLot")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, code])
  @@index([workspaceId])
}

model LotGenealogy {
  id       String @id @default(cuid())
  parentId String
  parent   Lot    @relation("ParentLot", fields: [parentId], references: [id], onDelete: Cascade)
  childId  String
  child    Lot    @relation("ChildLot", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

// ---------- Uzman danışma + içerik kürasyon (Phase 4: src/lib/expertConsult.ts, curation.ts) ----------
// DÜRÜSTLÜK NOTU: Bu iki varlık İŞLETMEYE ÖZGÜ DEĞİL — kürasyon/danışma platform-geneli
// referans veriyi hedefler (bir çiftliğin verisi değil, ürün bilgi grafiğinin kendisi),
// bu yüzden BİLİNÇLİ OLARAK workspaceId YOK (Listing/Task/Plan/Lot'un aksine). specialty/
// urgency/status/verification/escalationSource/subjectType alanları Listing.format ile aynı
// desen — düz string, DB seviyesinde enum zorlanmaz, TS union tek doğruluk kaynağı kalır.
// Expert.id KASITLI OLARAK cuid değil — sabit iş kodu ("exp-naz"), roster küçük/sabit/
// global olduğu için (crops.ts'e benzer, ama artık gerçek satır). ConsultationCase.answer
// akışı HÂLÂ dürüstçe sınırlı: hiçbir gerçek hesap EXPERTS rosterindeki bir kimliğe
// bağlanmadığı için (yeni bir "uzman hesabı" sistemi bu fazın kapsamı DIŞINDA), yanıtlama
// paneli önceki gibi hiçbir hesap için açılmaz — bu geçmişte de böyleydi, göç bunu değiştirmedi.

model Expert {
  id               String @id
  name             String
  credentials      String
  specialties      String[]
  verification     String
  avgResponseHours Int
  caseCount        Int    @default(0)

  cases ConsultationCase[]
}

model ConsultationCase {
  id               String    @id @default(cuid())
  askedBy          String
  cropId           String?
  specialty        String
  question         String
  urgency          String
  status           String    @default("acik")
  escalationSource String
  escalationReason String?
  assignedExpertId String?
  assignedExpert   Expert?   @relation(fields: [assignedExpertId], references: [id])
  assignedAt       DateTime?
  answer           String?
  answerEvidence   String?
  answeredAt       DateTime?
  closedAt         DateTime?
  createdAt        DateTime  @default(now())

  @@index([status])
  @@index([askedBy])
}

model CorrectionSubmission {
  id            String    @id @default(cuid())
  subjectType   String
  subjectId     String
  field         String
  currentValue  String
  proposedValue String
  sourceUrl     String?
  submittedBy   String
  status        String    @default("incelemede")
  version       Int
  reviewerId    String?
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime  @default(now())

  @@index([subjectId, field])
  @@index([status])
}

// ---------- Sensör (Phase 5: src/lib/sensors.ts) ----------
// DÜRÜSTLÜK NOTU: gerçek IoT donanımı yok — okumalar bu fazda MANUEL girilir (bkz.
// src/app/sensor/actions.ts). Bu, sahte bir simülatör/cron üretmek yerine bilinçli bir
// tercih: gerçek donanım bağlanana kadar "gerçek zamanlı otomatik veri akışı" iddiası
// uydurulmaz. qualityFlag DB'de SAKLANMAZ — flagAnomalies() ile her okunuşta yeniden
// hesaplanır (hesaplanmış çıktı kalıcılaştırılmaz ilkesi, Plan/AssessmentResult ile aynı).
model Device {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  code         String
  label        String
  zone         String
  type         String
  unit         String
  batteryPct   Int       @default(100)
  online       Boolean   @default(true)
  calibratedAt DateTime  @db.Date

  readings   Reading[]
  alertRules AlertRule[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
}

model Reading {
  id        String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  value     Float
  timestamp DateTime

  @@index([deviceId, timestamp])
}

model AlertRule {
  id             String @id @default(cuid())
  deviceId       String
  device         Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  comparator     String
  threshold      Float
  minConsecutive Int
  label          String
}

// ---------- Feature flag override (Phase 6: src/lib/featureFlags.ts) ----------
// FLAGS listesi ve evaluateFlag()/cohortBucket() SAF kalır (test edilmiş, değişmedi) —
// bu tablo yalnız workspace başına AÇIK override kaydeder (evaluateFlag'in "override >
// kohort > varsayılan" önceliğindeki ilk katman). Override yoksa cohortSeed=workspaceId
// ile deterministik kohort ataması devam eder.
model FeatureFlagOverride {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  flagKey         String
  value           Boolean
  updatedByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([workspaceId, flagKey])
  @@index([workspaceId])
}

// ---------- Mikro filiz oda/abonelik kapasitesi (Phase 6c: src/lib/microCapacity.ts) ----------
// effectiveCapacity()/planBackwards() SAF kalır — bu tablolar yalnız gerçek oda profilini ve
// restoran aboneliklerini saklar. Bir workspace'in TEK oda profili vardır (1:1, Plan modeliyle
// aynı desen); abonelikler doğrudan workspaceId taşır (Room'a roomId ile bağlamak bu MVP'de
// gereksiz bir dolaylama olurdu — tek oda varken).
model Room {
  id             String    @id @default(cuid())
  workspaceId    String    @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shelves        Int
  levelsPerShelf Int
  traysPerLevel  Int
  airflowFactor  Float
  updatedAt      DateTime  @updatedAt
}

model Subscription {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipeId     String
  traysPerWeek Int
  deliveryDay  Int
  createdAt    DateTime  @default(now())

  @@index([workspaceId])
}

// ---------- Maliyet döngüsü (Phase 6d: src/lib/costModel.ts) ----------
// computeCycleCost()/computeMargin()/computeContribution() SAF kalır. Yalnız GERÇEK, olmuş
// maliyet girdileri (CostEntry) kalıcı — marj hesaplayıcısının expectedYieldKg/wastePct/
// pricePerKgTRY girdileri BİLEREK persist edilmez (mikrofiliz tepsi hesaplayıcısıyla AYNI
// ilke: bunlar "ne olursa" tipi hipotetik senaryo girdileri, kesinleşmiş bir maliyet değil —
// hesaplanmış çıktı hiçbir zaman kalıcılaştırılmaz ilkesiyle tutarlı).
model CostCycle {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  label         String
  fixedCostsTRY Float    @default(0)
  allocation    String   // "alan-orani" | "dongu-basi"
  areaM2        Float?
  totalAreaM2   Float?
  cycles        Int?
  createdAt     DateTime @default(now())

  entries CostEntry[]

  @@index([workspaceId])
}

model CostEntry {
  id        String    @id @default(cuid())
  cycleId   String
  cycle     CostCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  category  String
  amountTRY Float
  note      String?
  createdAt DateTime  @default(now())

  @@index([cycleId])
}
